# ---------------------------------------------------------------------------
# 可提交源码范围（勿把下列路径写进忽略，除非确有本地-only 需求）
#   docs/、zensical.toml、.github/ — 站点内容与 CI
# 下列为本地或生成物，统一归类忽略
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 构建产物（CI 在干净环境生成，勿提交）
# ---------------------------------------------------------------------------
site/

# ---------------------------------------------------------------------------
# Python：虚拟环境与字节码（本地 zensical / pip）
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.egg-info/

# ---------------------------------------------------------------------------
# 工具缓存（Zensical 等；与 .cache 内自包含规则一致，根目录显式声明）
# ---------------------------------------------------------------------------
.cache/

# ---------------------------------------------------------------------------
# 操作系统
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# 编辑器与本地 Cursor 配置（不入库；含 plans、rules 等）
# ---------------------------------------------------------------------------
.cursor/

# ---------------------------------------------------------------------------
# 其他 IDE / 临时文件
# ---------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# 本地环境变量（若日后使用，勿提交）
# ---------------------------------------------------------------------------
.env
.env.local
