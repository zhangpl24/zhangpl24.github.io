# ---------------------------------------------------------------------------
# 构建产物（CI 在干净环境生成，勿提交）
# ---------------------------------------------------------------------------
site/

# ---------------------------------------------------------------------------
# Python：虚拟环境与字节码（本地 zensical / pip）
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc

# ---------------------------------------------------------------------------
# 工具缓存（Zensical 等；与 .cache 内自包含规则一致，根目录显式声明）
# ---------------------------------------------------------------------------
.cache/

# ---------------------------------------------------------------------------
# 操作系统
# ---------------------------------------------------------------------------
.DS_Store

# ---------------------------------------------------------------------------
# 编辑器与本地 Cursor 配置（不入库）
# ---------------------------------------------------------------------------
.cursor/

# ---------------------------------------------------------------------------
# 本地环境变量（若日后使用，勿提交）
# ---------------------------------------------------------------------------
.env
.env.local
